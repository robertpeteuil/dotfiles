#!/bin/bash
# cspell: disable
# shellcheck shell=bash
# shellcheck disable=SC1083

set -e

##  DOTFILES DOWNLOADER
#
#   A component of https://github.com/robertpeteuil/dotfiles
#

DOTFILES_REPO="robertpeteuil/dotfiles"
DOTFILES_PRIVATE_REPO="robertpeteuil/dotfiles-private"
DOTFILES_NVIM_REPO="robertpeteuil/dotfiles-nvim"
# must match $DOTFILES value set in zsh/.zshenv(13) and shell/bashrc(11)
DOTFILES_TARGET_DIR="$HOME/.dotfiles"

PRIVATE="private"
PRIVATEDIR="${DOTFILES_TARGET_DIR}/${PRIVATE}"
EXTERNALDIR="${DOTFILES_TARGET_DIR}/external"
NVIMDIR="${EXTERNALDIR}/nvim"
OS=$(uname -s)

if [ -d "$DOTFILES_TARGET_DIR" ]; then
  echo -e "ERROR: target dotfiles dir '${DOTFILES_TARGET_DIR}' exists.\n" >&2
  exit 1
fi

## INSTALL PREREQS
if ! [ -x "$(command -v git)" ]; then
  if [ "$OS" = 'Darwin' ]; then
    echo "installing: homebrew"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    echo "installing: git"
    brew install git
  elif [ "$OS" = 'Linux' ]; then
    sudo apt-get update -qq -y
    echo "installing: git"
    sudo apt-get install -y git
    # type python >/dev/null 2>&1 && echo "installing: python-distutils" && sudo apt-get install -y git python-distutils
    # type python3 >/dev/null 2>&1 && echo "installing: python3-distutils" && sudo apt-get install -y git python3-distutils
  fi
fi

## CLONE DOTFILES REPO
git clone --quiet --recursive --depth 1 "https://github.com/${DOTFILES_REPO}".git "$DOTFILES_TARGET_DIR"

## CLONE PRIVATE DOTFILES REPO IF EXIST
if [[ -d "${PRIVATEDIR}/.git" ]]; then
  echo "private repo present - updating"
  cd "${PRIVATEDIR}"
  git remote update -p >/dev/null 2>&1
  git merge --ff-only @{u} >/dev/null 2>&1
elif git clone --quiet --depth 1 "git@github.com:${DOTFILES_PRIVATE_REPO}.git" "${PRIVATEDIR}" 2>/dev/null; then
  echo "private repo cloned"
fi

## CLONE PUBLIC NVIM DOTFILES REPO IF AVAILABLE
# This optional split repo backs the conditional ~/.config/nvim Dotbot link.
# Warn and continue on clone/update failure so the rest of Dotbot can still run.
if [[ -d "${NVIMDIR}/.git" ]]; then
  echo "nvim repo present - updating"
  cd "${NVIMDIR}"
  if ! git remote update -p >/dev/null 2>&1 || ! git merge --ff-only @{u} >/dev/null 2>&1; then
    echo "WARNING: dotfiles-nvim update failed; continuing without updating nvim config" >&2
  fi
elif [[ ! -e "${NVIMDIR}" ]] || [[ -z "$(ls -A "${NVIMDIR}" 2>/dev/null)" ]]; then
  mkdir -p "${EXTERNALDIR}"
  if git clone --quiet --depth 1 "https://github.com/${DOTFILES_NVIM_REPO}.git" "${NVIMDIR}" 2>/dev/null; then
    echo "nvim repo cloned"
  else
    echo "WARNING: dotfiles-nvim clone failed; continuing without nvim config" >&2
  fi
else
  echo "WARNING: ${NVIMDIR} exists but is not a Git clone; skipping dotfiles-nvim" >&2
fi

## RUN DOTBOT INSTALLER
cd "$DOTFILES_TARGET_DIR" || exit 1
ssh-keyscan -H github.com >>~/.ssh/known_hosts
./install

# vim: ft=bash
